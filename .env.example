# Copy to .env.local and fill in. Never commit .env.local.
# All three values come from one Supabase project.

# --- Supabase Auth (client-safe) -------------------------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."   # anon / publishable key — safe in the browser

# --- Database (Drizzle, server-only) ---------------------------------------
# Supabase Dashboard → Connect → ORMs / Connection string.
#
# Use the TRANSACTION POOLER (port 6543) for the app — it suits serverless.
# The app driver sets prepare:false, which that pooler requires.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Use the SESSION POOLER / direct connection (port 5432) for migrations.
# drizzle-kit needs it; the transaction pooler can't run DDL reliably.
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- SnapTrade (server-only) ------------------------------------------------
# SnapTrade dashboard → API keys. Never expose these to the browser.
SNAPTRADE_CLIENT_ID=""
SNAPTRADE_CONSUMER_KEY=""

# --- Secret encryption ------------------------------------------------------
# Encrypts provider secrets at rest (AES-256-GCM). Must decode to 32 bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Rotating this key makes every stored secret undecryptable. SnapTrade user
# secrets cannot be recovered or reset without the original, so losing this key
# means users must reconnect their brokerage. Back it up.
ENCRYPTION_KEY=""
